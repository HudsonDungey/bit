# ─── Sepolia + Alchemy + WalletConnect ─────────────────────────────────────
# Copy to .env.local and fill in. .env.local is gitignored.

# Public Alchemy API key (Sepolia). Used by both the browser (NEXT_PUBLIC_) and the server.
# Get one at https://dashboard.alchemy.com/  →  create an app on "Ethereum Sepolia".
NEXT_PUBLIC_ALCHEMY_KEY=

# WalletConnect Cloud project id — required for RainbowKit's WalletConnect transport.
# Get one at https://cloud.reown.com/  (formerly cloud.walletconnect.com).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Server-only: private key for the off-chain scheduler (calls manager.charge on Sepolia).
# Use a DEDICATED Sepolia EOA. Fund with a small amount of Sepolia ETH for gas.
# Format: 0x-prefixed 64-char hex.
EXECUTOR_PRIVATE_KEY=
